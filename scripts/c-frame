#!/usr/bin/env bash
set -euo pipefail

file="$1"
tmp="$(mktemp --suffix=.png)"

duration="$(ffprobe -v error -show_entries format=duration -of default=nw=1:nk=1 "$file" || echo 5)"
timestamp="$(awk -v d="$duration" 'BEGIN { t=d*0.10; if (t<1) t=0.5; print t }')"

ffmpeg -y -ss "$timestamp" -i "$file" -frames:v 1 "$tmp" >/dev/null 2>&1
xclip -selection clipboard -t image/png -i "$tmp"

notify-send "c-frame" "Frame copied."
